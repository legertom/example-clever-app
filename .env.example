# Copy to .env.local and fill in. Never commit real secrets.

# --- Clever SSO (per-user login) ---
# From https://apps.clever.com -> your app -> OAuth settings
CLEVER_CLIENT_ID=
CLEVER_CLIENT_SECRET=
# Must EXACTLY match a redirect URI registered on your Clever app.
# Local dev:        http://localhost:3000/api/oauth/callback
# Vercel production: https://<your-app>.vercel.app/api/oauth/callback
CLEVER_REDIRECT_URI=http://localhost:3000/api/oauth/callback

# Encrypts the iron-session cookie. Generate: openssl rand -base64 32
SESSION_PASSWORD=

# --- Clever Secure Sync (district roster data) ---
# Sandbox district Bearer token from:
# Clever App Dashboard -> Data Sources -> Sandbox District -> API Token
CLEVER_DISTRICT_TOKEN=

# Protects the /api/cron/sync endpoint. Vercel Cron sends this as a Bearer token.
# Generate: openssl rand -base64 32
CRON_SECRET=

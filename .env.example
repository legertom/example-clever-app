# Copy to .env and fill in values from your Clever app dashboard:
# https://apps.clever.com  ->  your app  ->  OAuth settings

# OAuth credentials issued by Clever
CLEVER_CLIENT_ID=
CLEVER_CLIENT_SECRET=

# Must EXACTLY match a redirect URI registered on your Clever app
CLEVER_REDIRECT_URI=http://localhost:3000/oauth/callback

# Random string used to sign the session cookie (any long random value)
SESSION_SECRET=change-me-to-a-long-random-string

# Optional
PORT=3000
